:80 {
	# API — FastAPI handles JWT auth
	handle /api/* {
		reverse_proxy localhost:8000
	}

	# Dashboard and all SPA routes (including public interview under /dashboard/interview/*)
	handle /dashboard* {
		reverse_proxy localhost:3000
	}

	# Homepage — static landing page
	handle {
		root * landing
		file_server
	}
}
