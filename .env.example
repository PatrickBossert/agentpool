# .env.example — copy to .env and fill in real values (never commit .env)

# ── Anthropic / LLM ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LITELLM_PROXY_URL=http://localhost:4000
LLAMACPP_BASE_URL=http://localhost:10000
LOCAL_LLM_MODEL=local-model

# ── Admin credentials (required — app will not start without these) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── ChromaDB ─────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8002
# For ChromaDB Cloud — set CHROMA_API_KEY to use CloudClient instead of HttpClient
CHROMA_API_KEY=
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# ── Storage ──────────────────────────────────────────────────────
DATABASE_DIR=./data
PROJECTS_DIR=./projects

# ── URLs ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PUBLIC_URL=http://localhost:3000
# Production: set to your public domain, e.g. https://futuremomentum.ai
# PUBLIC_URL=https://futuremomentum.ai

# ── n8n ──────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/agentpool
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-in-production

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=FutureMomentum <noreply@futuremomentum.ai>

# ── Voice / Transcription ─────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Pinecone (vector database) ───────────────────────────────────
PINECONE_API_KEY=pcsk_...

# ── Web search ───────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Cloudflare Tunnel (production only) ──────────────────────────
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# ── Slack app credentials — entered in n8n UI (Credentials → New → Slack OAuth2 API) ──
# NOT used directly by the Python app
# SLACK_APP_ID=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_VERIFICATION_TOKEN=
